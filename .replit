language = "python3"
run = "python3 manage.py runserver 0.0.0.0:3000"
modules = ["python-3.11"]

[env]
DEBUG = "True"
DJANGO_SETTINGS_MODULE = "django_project.settings"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 8000

[nix]
packages = ["cairo", "ffmpeg-full", "freetype", "ghostscript", "gobject-introspection", "gtk3", "pkg-config", "qhull", "tcl", "tk"]

[agent]
expertMode = true
